@model ClinicalTrial2._0.Models.Trial

@{
    ViewData["Title"] = "Trial Details - " + Model.TrialName;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-action="Index">Trials</a></li>
                            <li class="breadcrumb-item active">@Model.NCTNumber</li>
                        </ol>
                    </nav>
                    <h1>@Model.TrialName</h1>
                    <p class="lead text-muted">NCT Number: @Model.NCTNumber</p>
                </div>
                <div>
                    <span class="badge bg-info fs-6 me-2">Phase @Model.TrialPhase</span>
                    @if (Model.TrialStartDate <= DateTime.Today && Model.TrialEndDate >= DateTime.Today)
                    {
                        <span class="badge bg-success fs-6">Active</span>
                    }
                    else if (Model.TrialStartDate > DateTime.Today)
                    {
                        <span class="badge bg-warning fs-6">Upcoming</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6">Completed</span>
                    }
                </div>
            </div>

            <div class="row">
                <!-- Main Content -->
                <div class="col-lg-8">
                    <!-- Description -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5><i class="fas fa-info-circle me-2"></i>Trial Description</h5>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <p>@Model.Description</p>
                            }
                            else
                            {
                                <p class="text-muted">No description available.</p>
                            }
                        </div>
                    </div>

                    <!-- Trial Details -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5><i class="fas fa-clipboard-list me-2"></i>Trial Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <strong><i class="fas fa-disease me-2"></i>Disease/Condition:</strong>
                                    <p class="mb-0">@Model.Disease.DiseaseName</p>
                                    @if (!string.IsNullOrEmpty(Model.Disease.Description))
                                    {
                                        <small class="text-muted">@Model.Disease.Description</small>
                                    }
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong><i class="fas fa-map-marker-alt me-2"></i>Location:</strong>
                                    <p class="mb-0">@Model.Location.FullAddress</p>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong><i class="fas fa-calendar-alt me-2"></i>Start Date:</strong>
                                    <p class="mb-0">@Model.TrialStartDate.ToString("MMMM dd, yyyy")</p>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong><i class="fas fa-calendar-check me-2"></i>End Date:</strong>
                                    <p class="mb-0">@Model.TrialEndDate.ToString("MMMM dd, yyyy")</p>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Sex))
                                {
                                    <div class="col-md-6 mb-3">
                                        <strong><i class="fas fa-user me-2"></i>Gender Requirements:</strong>
                                        <p class="mb-0">@Model.Sex</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.AgeRange))
                                {
                                    <div class="col-md-6 mb-3">
                                        <strong><i class="fas fa-birthday-cake me-2"></i>Age Range:</strong>
                                        <p class="mb-0">@Model.AgeRange</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Treatments -->
                    @if (Model.TrialTreatments.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5><i class="fas fa-pills me-2"></i>Treatments</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    @foreach (var trialTreatment in Model.TrialTreatments)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="border rounded p-3">
                                                <h6>@trialTreatment.Treatment.TreatmentName</h6>
                                                @if (!string.IsNullOrEmpty(trialTreatment.Treatment.Description))
                                                {
                                                    <p class="text-muted mb-1">@trialTreatment.Treatment.Description</p>
                                                }
                                                @if (!string.IsNullOrEmpty(trialTreatment.Treatment.TreatmentType))
                                                {
                                                    <span class="badge bg-light text-dark">@trialTreatment.Treatment.TreatmentType</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- External Links -->
                    @if (!string.IsNullOrEmpty(Model.URL))
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5><i class="fas fa-external-link-alt me-2"></i>External Resources</h5>
                            </div>
                            <div class="card-body">
                                <a href="@Model.URL" target="_blank" class="btn btn-outline-primary">
                                    <i class="fas fa-external-link-alt me-2"></i>View on ClinicalTrials.gov
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <!-- Enrollment Action -->
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-user-plus me-2"></i>Interested in Participating?</h5>
                        </div>
                        <div class="card-body text-center">
                            @if (Model.TrialStartDate <= DateTime.Today && Model.TrialEndDate >= DateTime.Today)
                            {
                                <p>This trial is currently recruiting participants.</p>
                                <form asp-action="Enroll" method="post">
                                    <input type="hidden" name="id" value="@Model.TrialId" />
                                    <button type="submit" class="btn btn-success btn-lg w-100">
                                        <i class="fas fa-user-check me-2"></i>Enroll Now
                                    </button>
                                </form>
                            }
                            else if (Model.TrialStartDate > DateTime.Today)
                            {
                                <p>This trial will begin on @Model.TrialStartDate.ToString("MMMM dd, yyyy").</p>
                                <button class="btn btn-secondary btn-lg w-100" disabled>
                                    <i class="fas fa-clock me-2"></i>Not Yet Open
                                </button>
                            }
                            else
                            {
                                <p>This trial has ended.</p>
                                <button class="btn btn-secondary btn-lg w-100" disabled>
                                    <i class="fas fa-times me-2"></i>Trial Ended
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Contact Information -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-user-md me-2"></i>Principal Investigator</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>@Model.CreatedBy.FullName</strong></p>
                            <p class="text-muted mb-2">@Model.CreatedBy.Email</p>
                            @if (!string.IsNullOrEmpty(Model.CreatedBy.PhoneNumber))
                            {
                                <p class="text-muted">@Model.CreatedBy.PhoneNumber</p>
                            }
                        </div>
                    </div>

                    <!-- Quick Stats -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Trial Statistics</h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-6">
                                    <h4 class="text-primary">@Model.Enrollments.Count()</h4>
                                    <small class="text-muted">Total Enrollments</small>
                                </div>
                                <div class="col-6">
                                    <h4 class="text-success">@Model.Enrollments.Count(e => e.Status == "Approved")</h4>
                                    <small class="text-muted">Approved</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
