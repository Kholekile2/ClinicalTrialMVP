@model IEnumerable<ClinicalTrial2._0.Models.Trial>

@{
    ViewData["Title"] = "Browse Clinical Trials";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="fas fa-search me-2"></i>Browse Clinical Trials</h1>
                <span class="badge bg-primary fs-6">@Model.Count() trials available</span>
            </div>
            
            <!-- Search and Filter Section -->
            <div class="card mb-4">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label for="search" class="form-label">Search</label>
                            <input type="text" name="search" value="@ViewBag.Search" class="form-control" 
                                   placeholder="Search trials, diseases, NCT numbers..." />
                        </div>
                        <div class="col-md-3">
                            <label for="diseaseId" class="form-label">Disease</label>
                            <select name="diseaseId" class="form-select">
                                <option value="">All Diseases</option>
                                @foreach (var disease in ViewBag.Diseases)
                                {
                                    <option value="@disease.DiseaseId" selected="@(ViewBag.SelectedDiseaseId == disease.DiseaseId)">
                                        @disease.DiseaseName
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="locationId" class="form-label">Location</label>
                            <select name="locationId" class="form-select">
                                <option value="">All Locations</option>
                                @foreach (var location in ViewBag.Locations)
                                {
                                    <option value="@location.LocationId" selected="@(ViewBag.SelectedLocationId == location.LocationId)">
                                        @location.City, @location.Province
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-filter me-1"></i>Filter
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Trials Grid -->
            <div class="row">
                @if (Model.Any())
                {
                    @foreach (var trial in Model)
                    {
                        <div class="col-lg-6 col-xl-4 mb-4">
                            <div class="card h-100 shadow-sm trial-card">
                                <div class="card-header bg-light">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="mb-0 text-primary">@trial.NCTNumber</h6>
                                        <span class="badge bg-info">Phase @trial.TrialPhase</span>
                                    </div>
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@trial.TrialName</h5>
                                    <p class="card-text text-muted">
                                        @if (!string.IsNullOrEmpty(trial.Description))
                                        {
                                            @(trial.Description.Length > 100 ? trial.Description.Substring(0, 100) + "..." : trial.Description)
                                        }
                                    </p>
                                    
                                    <div class="mt-auto">
                                        <div class="row text-muted small mb-3">
                                            <div class="col-6">
                                                <i class="fas fa-map-marker-alt me-1"></i>@trial.Location.City
                                            </div>
                                            <div class="col-6">
                                                <i class="fas fa-disease me-1"></i>@trial.Disease.DiseaseName
                                            </div>
                                        </div>
                                        
                                        <div class="row text-muted small mb-3">
                                            <div class="col-6">
                                                <i class="fas fa-calendar-alt me-1"></i>@trial.TrialStartDate.ToString("MMM yyyy")
                                            </div>
                                            <div class="col-6">
                                                @if (!string.IsNullOrEmpty(trial.Sex))
                                                {
                                                    <i class="fas fa-user me-1"></i>@trial.Sex
                                                }
                                            </div>
                                        </div>
                                        
                                        <a asp-action="Details" asp-route-id="@trial.TrialId" 
                                           class="btn btn-primary btn-sm w-100">
                                            <i class="fas fa-info-circle me-1"></i>View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                <h4>No trials found</h4>
                                <p class="text-muted">Try adjusting your search criteria or filters.</p>
                                <a asp-action="Index" class="btn btn-primary">
                                    <i class="fas fa-refresh me-1"></i>View All Trials
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .trial-card {
            transition: transform 0.2s ease-in-out;
        }
        .trial-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
        }
    </style>
}
