@model IEnumerable<ClinicalTrial2._0.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrollments";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1><i class="fas fa-user-check me-2"></i>My Enrollments</h1>
                    <p class="text-muted">Track your clinical trial enrollment status</p>
                </div>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-search me-2"></i>Browse More Trials
                </a>
            </div>

            @if (Model.Any())
            {
                <div class="row">
                    @foreach (var enrollment in Model)
                    {
                        <div class="col-lg-6 col-xl-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">@enrollment.Trial.NCTNumber</h6>
                                    @switch (enrollment.Status)
                                    {
                                        case "Pending":
                                            <span class="badge bg-warning">Pending Review</span>
                                            break;
                                        case "Approved":
                                            <span class="badge bg-success">Approved</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger">Rejected</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-info">Completed</span>
                                            break;
                                        case "Withdrawn":
                                            <span class="badge bg-secondary">Withdrawn</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark">@enrollment.Status</span>
                                            break;
                                    }
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@enrollment.Trial.TrialName</h5>
                                    
                                    <div class="mb-3">
                                        <div class="row text-muted small">
                                            <div class="col-6">
                                                <i class="fas fa-map-marker-alt me-1"></i>@enrollment.Trial.Location.City
                                            </div>
                                            <div class="col-6">
                                                <i class="fas fa-disease me-1"></i>@enrollment.Trial.Disease.DiseaseName
                                            </div>
                                        </div>
                                        <div class="row text-muted small mt-1">
                                            <div class="col-6">
                                                <i class="fas fa-calendar-alt me-1"></i>Enrolled: @enrollment.EnrollmentDate.ToString("MMM dd, yyyy")
                                            </div>
                                            <div class="col-6">
                                                <i class="fas fa-flask me-1"></i>Phase @enrollment.Trial.TrialPhase
                                            </div>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(enrollment.Notes))
                                    {
                                        <div class="alert alert-info py-2" role="alert">
                                            <small><strong>Notes:</strong> @enrollment.Notes</small>
                                        </div>
                                    }

                                    <div class="mt-auto">
                                        <a asp-action="Details" asp-route-id="@enrollment.Trial.TrialId" 
                                           class="btn btn-outline-primary btn-sm w-100">
                                            <i class="fas fa-eye me-1"></i>View Trial Details
                                        </a>
                                    </div>
                                </div>
                                @if (enrollment.StatusUpdatedDate.HasValue)
                                {
                                    <div class="card-footer text-muted">
                                        <small>Status updated: @enrollment.StatusUpdatedDate.Value.ToString("MMM dd, yyyy")</small>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-user-check fa-3x text-muted mb-3"></i>
                                <h4>No Enrollments Yet</h4>
                                <p class="text-muted">You haven't enrolled in any clinical trials yet. Browse available trials to get started.</p>
                                <a asp-action="Index" class="btn btn-primary btn-lg">
                                    <i class="fas fa-search me-2"></i>Browse Clinical Trials
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
